# ── Base de datos ──────────────────────────────────────────
# Local/Docker Postgres. Para migrar a Supabase, solo reemplazar esta URL
# (y opcionalmente DIRECT_URL para pooling) sin tocar código ni schema.
DATABASE_URL="postgresql://yerbatapp:yerbatapp@localhost:5432/yerbatapp?schema=public"
# DIRECT_URL="postgresql://yerbatapp:yerbatapp@localhost:5432/yerbatapp?schema=public"

# ── Servidor ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:5173

# ── JWT ────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Bcrypt ─────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── Rate limit ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# ── Uploads ────────────────────────────────────────────────
UPLOADS_DIR=./uploads
MAX_UPLOAD_MB=10

# ── Mailer (recuperación de contraseña) ───────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="YerbatApp <no-reply@yerbatapp.com>"

# ── Backups (pg_dump/psql) ─────────────────────────────────
# En Docker/producción, con el cliente de Postgres instalado en el PATH del
# contenedor alcanza con dejar "pg_dump"/"psql". En Windows local normalmente
# hace falta la ruta completa, ej:
# PG_DUMP_PATH="C:\Program Files\PostgreSQL\16\bin\pg_dump.exe"
# PSQL_PATH="C:\Program Files\PostgreSQL\16\bin\psql.exe"
PG_DUMP_PATH=pg_dump
PSQL_PATH=psql
BACKUPS_DIR=./backups
BACKUP_CRON_SCHEDULE="0 3 * * *"
ALERTAS_CRON_SCHEDULE="0 7 * * *"

# ── Tenant por defecto (seed) ──────────────────────────────
DEFAULT_TENANT_NAME="Yerbatera Demo S.A."
DEFAULT_ADMIN_EMAIL=admin@yerbatapp.com
DEFAULT_ADMIN_PASSWORD=Admin1234

# ── Cliente (Vite) ─────────────────────────────────────────
VITE_API_URL=http://localhost:4000/api/v1
