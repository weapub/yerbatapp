# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
build/
**/dist/
**/build/
*.tsbuildinfo

# Env
.env
.env.local
.env.*.local
!.env.example

# Logs
*.log
npm-debug.log*
logs/

# Uploads y backups (contenido subido/generado en runtime, no versionado).
# resolveFromRepoRoot() siempre los resuelve relativos a la raíz del repo, nunca
# anidados — el "/" inicial es a propósito: "**/backups/*" (sin anclar) también
# matcheaba server/src/modules/backups/ (el módulo de código) y lo dejaba afuera
# del repo por error.
/uploads/*
!/uploads/.gitkeep
/backups/*
!/backups/.gitkeep

# Prisma
database/prisma/migrations/dev/

# Test / coverage
coverage/

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.claude/
.DS_Store
Thumbs.db

# Docker
docker/nginx/certbot/

# Vite
client/.vite/
